{
  "rules": {
    "presence": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "messages": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".indexOn": ["timestamp"]
    },
    "analytics": {
      "visits": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".write": "auth != null",
        ".indexOn": ["timestamp"]
      },
      "sessions": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".write": "auth != null",
        ".indexOn": ["userId", "timestamp"]
      }
    },
    "userStats": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt"]
    },
    "activityFeed": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"]
    },
    "userProgress": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "bannedUsers": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "admins": {
      ".read": "auth != null",
      ".write": false
    },
    "appConfig": {
      "inviteCode": {
        ".read": true,
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    }
  }
}